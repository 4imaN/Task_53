{
  "name": "omnistock-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "ng serve --host 0.0.0.0 --port 4200 --proxy-config proxy.conf.json",
    "preview": "node ./scripts/preview.mjs",
    "build": "CI=1 NG_CLI_ANALYTICS=false ng build --progress=false",
    "test": "/bin/zsh -lc 'unset npm_lifecycle_event npm_lifecycle_script npm_command; npm run test:ui && npm run test:unit'",
    "test:unit": "node --import tsx --test ./test/unit/*.test.ts",
    "test:ui": "./scripts/run-playwright.sh",
    "test:ui:local": "./scripts/run-playwright-local.sh",
    "test:ui:live": "cd ../.. && ./scripts/frontend-live-stack-smoke.sh"
  },
  "dependencies": {
    "@angular/animations": "^19.2.6",
    "@angular/common": "^19.2.6",
    "@angular/compiler": "^19.2.6",
    "@angular/core": "^19.2.6",
    "@angular/forms": "^19.2.6",
    "@angular/platform-browser": "^19.2.6",
    "@angular/platform-browser-dynamic": "^19.2.6",
    "@angular/router": "^19.2.6",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^19.2.6",
    "@angular/cli": "^19.2.6",
    "@angular/compiler-cli": "^19.2.6",
    "@playwright/test": "^1.58.2",
    "jsdom": "^29.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
