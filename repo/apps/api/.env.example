# OmniStock API local (non-Docker) environment template
# Copy this file to apps/api/.env.local and set secure values.

# Required for local API commands (migrate/bootstrap/dev)
JWT_SECRET=
ENCRYPTION_KEY=
DEFAULT_ADMIN_PASSWORD=

# Optional overrides
DEFAULT_ADMIN_USERNAME=admin
SEED_DEMO_USERS=0

# Optional DB override.
# If omitted, API falls back to:
# postgres://<local-username>@localhost:5432/postgres
# DATABASE_URL=
