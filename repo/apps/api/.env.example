# OmniStock API local (non-Docker) environment template
# Copy this file to apps/api/.env.local and set secure values.
# Or run ../../scripts/bootstrap-local-dev.mjs to generate this file safely.

# Required for local API commands (migrate/bootstrap/dev)
APP_ENV=development
TRUST_PROXY=0
JWT_SECRET=
ENCRYPTION_KEY=
DEFAULT_ADMIN_PASSWORD=
ALLOW_INSECURE_DEV_COOKIES=1
ALLOW_DEV_WEBHOOK_LOOPBACK=1

# Optional overrides
DEFAULT_ADMIN_USERNAME=admin
SEED_DEMO_USERS=0
LOGIN_HINTS_RATE_LIMIT_MAX=15
LOGIN_HINTS_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_DELIVERY_RETENTION_DAYS=30
WEBHOOK_ALLOWED_HOSTNAMES=
WEBHOOK_ALLOWED_DOMAIN_SUFFIXES=

# Optional DB override.
# If omitted, API falls back to:
# postgres://<local-username>@localhost:5432/postgres
# DATABASE_URL=
