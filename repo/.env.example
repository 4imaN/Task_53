COMPOSE_PROJECT_NAME=omnistock
POSTGRES_DB=omnistock
POSTGRES_USER=omnistock
POSTGRES_PASSWORD=omnistock_local
DATABASE_URL=postgres://omnistock:omnistock_local@omnistock-db:5432/omnistock
JWT_SECRET=
SESSION_TTL_HOURS=24
SESSION_IDLE_TIMEOUT_MINUTES=120
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
PASSWORD_HISTORY_DEPTH=5
CAPTCHA_TTL_MINUTES=10
CAPTCHA_FAILURE_THRESHOLD=3
LOGIN_LOCKOUT_ATTEMPTS=7
LOGIN_LOCKOUT_MINUTES=15
UPLOAD_ROOT=/data/uploads
UPLOAD_QUOTA_GB=50
ENCRYPTION_KEY=
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
SEED_DEMO_USERS=0
INTEGRATION_RATE_LIMIT=120
APP_PORT=3000
WEB_PORT=80
